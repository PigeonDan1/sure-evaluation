include README.md LICENSE pyproject.toml
recursive-include src/sure_eval/evaluation/tasks *.yaml *.yml *.md
recursive-include src/sure_eval/evaluation/conversion *.yaml *.md
include src/sure_eval/evaluation/nodes/*/*/manifest.yaml
include src/sure_eval/evaluation/nodes/*/*/node_env.yaml
include src/sure_eval/evaluation/nodes/*/*/README.md
include src/sure_eval/evaluation/nodes/scoring/sctk_sclite/*.sh
include src/sure_eval/reports/sota/*.yaml
prune src/sure_eval/evaluation/nodes/*/*/checkpoints
prune src/sure_eval/evaluation/nodes/*/*/.venv
prune src/sure_eval/evaluation/nodes/*/*/.cache
prune build
prune dist
prune runtime
prune .venv
prune .venv.hostbak
global-exclude *.ckpt *.pt *.pth *.onnx *.safetensors *.bin
global-exclude __pycache__ *.py[cod]
